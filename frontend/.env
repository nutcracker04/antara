# Copy to `.env.development.local` (recommended) or `.env` in this folder.
# See: https://create-react-app.dev/docs/adding-custom-environment-variables/

# Base URL of the FastAPI backend (no trailing slash). Used for `/api/health` in the header chip.
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional: set when the app is served under a subpath (e.g. GitHub Pages).
# PUBLIC_URL=

# Optional: enable webpack dev-server health endpoints (see craco.config.js).
# ENABLE_HEALTH_CHECK=false
